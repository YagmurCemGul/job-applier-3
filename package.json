{
  "name": "job-applier-3",
  "version": "1.0.0",
  "description": "Electron + React desktop application for automated job applications",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "esbuild src/renderer/index.tsx --bundle --outdir=dist/renderer --watch --servedir=dist/renderer --port=3000 --loader:.tsx=tsx --loader:.ts=tsx",
    "dev:main": "esbuild src/main/main.ts --bundle --outdir=dist --platform=node --external:electron --watch",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "esbuild src/renderer/index.tsx --bundle --outdir=dist/renderer --minify --loader:.tsx=tsx --loader:.ts=tsx",
    "build:main": "esbuild src/main/main.ts --bundle --outdir=dist --platform=node --external:electron --external:keytar --external:better-sqlite3 --external:playwright --minify",
    "start": "electron .",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["electron", "react", "typescript", "job-application", "automation"],
  "author": "YagmurCemGul",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.3",
    "@types/react": "^18.2.22",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "concurrently": "^8.2.1",
    "electron": "^26.2.1",
    "esbuild": "^0.19.3",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.6.3",
    "@google-ai/generativelanguage": "^2.4.0",
    "better-sqlite3": "^8.7.0",
    "dotenv": "^16.3.1",
    "google-auth-library": "^9.1.0",
    "keytar": "^7.9.0",
    "openai": "^4.8.0",
    "playwright": "^1.38.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "winston": "^3.10.0"
  }
}